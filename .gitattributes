# Force LF line endings in the repository for all text;
# Windows checkouts still see CRLF in the working copy when
# core.autocrlf=true. Prevents flip-flop of line endings on push/pull.
* text=auto eol=lf

# Keep platform-native line endings for these:
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary — never normalize:
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.pt    binary
*.pth   binary
*.ckpt  binary
*.safetensors binary
*.bin   binary
*.npy   binary
*.npz   binary
*.zip   binary
*.tar.gz binary
